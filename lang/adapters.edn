{:kotoba.adapter.registry/version 1
 :kotoba.adapter.registry/source :kotoba-lang
 :kotoba.adapter.registry/policy
 {:rust-in-default-repo? false
  :native-implementation "Native launchers are adapter repositories that consume lang/cli.edn and kotoba.cli/dispatch."}
 :kotoba.adapter.registry/adapters
 [{:id :adapter/node-cli
   :kind :node
   :repository "kotoba-lang/kotoba-node-adapter"
   :consumes #{:kotoba.cli/dispatch :kotoba.cli.contract/commands}
   :provides #{:kotoba.cli/process}}
  {:id :adapter/jvm-cli
   :kind :jvm
   :repository "kotoba-lang/kotoba-jvm-adapter"
   :consumes #{:kotoba.cli/dispatch :kotoba.cli.contract/commands}
   :provides #{:kotoba.cli/process}}
  {:id :adapter/native-cli
   :kind :native
   :repository "kotoba-lang/kotoba-native-adapter"
   :consumes #{:kotoba.cli/dispatch :kotoba.cli.contract/commands}
   :provides #{:kotoba.cli/process}}]}
