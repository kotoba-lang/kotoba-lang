{:kotoba.lang.safety-qualification/version 1
 :kotoba.lang.safety-qualification/as-of "2026-07-18"
 :kotoba.lang.safety-qualification/authority "kotoba-lang/kotoba-lang"
 :kotoba.lang.safety-qualification/adr
 "adr-2607183900-kotoba-component-language-runtime-roles"

 :terms
 {:kotoba-source
  {:definition
   "Canonical .kotoba capability-safe component source. It has no ambient authority and every external effect is a declared import; the extension does not imply pure-only or guest-only execution."
   :may [:pure-computation :orchestration :policy :protocol-provider
         :http-client :database-driver :explicit-capability-values]
   :must-not [:eval :ambient-require :host-interop :undeclared-effect
              :self-minted-grant :direct-unmediated-syscall]}
  :component
  {:definition
   "An emitted unit with explicit imports, exports, effect closure and resource limits. It may supply higher-level capabilities while importing lower-level capabilities."
   :roles-are-runtime-relative true}
  :guest
  {:definition
   "A component relative to the runtime or provider that instantiates it and supplies its imports. Guest is not a source extension or permanent trust class."}
  :host
  {:definition
   "A runtime or component relative to a downstream component whose import it supplies. A Kotoba provider may be a host downstream and a guest of lower-level imports upstream."
   :does-not-imply [:ambient-authority :native-code :unbounded-trust]}
  :native-primitive
  {:definition
   "Minimal trusted boundary from typed component imports to the Wasm engine, WASI, OS syscall, device or root secret store. It revalidates concrete resource scope and cannot be removed by changing an extension."
   :owns [:raw-binding :root-scope-check :runtime-interruption]
   :must-be-minimized true}
  :broker
  {:definition
   "Authority above the tender that decides which principal may receive which scoped grant. aiueos is the named OS/capability broker."
   :owns [:identity :policy-decision :grant-attenuation :revocation]}
  :tender
  {:definition
   "Runtime that verifies/instantiates already-emitted Wasm components, links declared imports and exports, and binds only granted capabilities. kototama owns this role."
   :owns [:artifact-admission :wasm-instantiation :import-export-linking
          :fuel-memory-output-enforcement :execution-report]}}

 :capability-invariant
 {:statement
  "A component can exercise an external effect iff the language admits the explicit effect, the compiler emits the corresponding import, policy grants the exact scoped capability, the tender links and binds it, and the final provider or native primitive revalidates its resource scope."
 :chain
 [:component-source :language-effect :compiler-import :signed-policy-grant
  :tender-link-binding :provider-or-native-scope-check :external-effect]
 :fail-closed-at-every-edge true
 :no-wildcard-authority true
 :same-language-provider-does-not-bypass-imports true
 :defense-in-depth
 [:static-subset :typed-effect-analysis :artifact-verification
  :runtime-quota :host-scope-check :os-sandbox]}

 :repository-roles
 {:kotoba-lang/kotoba-lang
  {:role :semantic-contract
   :owns [:source-profile :component-role-model :least-authority-grammar
          :capability-semantics
          :conformance :this-qualification-contract]}
  :kotoba-lang/kotoba
  {:role :reference-language-and-wasm-emitter
   :owns [:reference-reader :reference-admission :kotoba-wasm-emission
          :proof-harness]
   :not-production-runtime true}
  :kotoba-lang/compiler
  {:role :deny-by-default-multitarget-compiler
   :owns [:typed-effect-hir :kir :wasm-native-cljs-backends
          :independent-artifact-verifier]}
  :kotoba-lang/kototama
  {:role :wasm-component-tender-and-linker
   :owns [:already-emitted-component-execution :import-export-linking
          :granted-capability-binding
          :runtime-resource-enforcement]
   :does-not-own [:grammar :compilation :grant-decision :fleet-control-plane]}
  :kotoba-lang/aiueos
  {:role :os-and-capability-broker
   :owns [:principal-policy :scoped-grants :revocation :os-isolation]}
  :kotoba-lang/murakumo
  {:role :distributed-hosting-control-plane
   :owns [:desired-state :placement :reconciliation :fleet-lifecycle]}}

 :comparisons
 {:deno
  {:similar [:deny-by-default-permissions :explicit-fs-net-env-boundaries
             :runtime-mediated-effects]
   :different
   ["Deno permissions primarily constrain JavaScript/TypeScript at runtime and process/CLI grant boundaries."
    "Kotoba additionally intends capability values, compile-time effect/import closure, artifact verification, signed policy and host-side resource-scope revalidation."
    "Kotoba component code deliberately excludes general JavaScript/JVM interop and ambient package loading; provider components still use declared imports."]
   :conclusion :same-family-of-least-authority-not-equivalent}
  :wasmcloud
  {:kototama-analogy :single-host-runtime-tender
   :murakumo-analogy :wasmcloud-wadm-control-plane
   :provider-analogy :narrow-host-capability-handler
   :different
   ["kototama alone is not a lattice, scheduler, reconciler or distributed control plane."
    "aiueos decides grants; kototama enforces them."
    "murakumo owns fleet placement and reconciliation."]
   :conclusion :stack-level-analogy-not-repository-equivalence}}

