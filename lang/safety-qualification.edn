 ;; Goal-first reverse topological order: use this for design review and to
 ;; decompose the migration objective back to its foundations.
 :reverse-topological-design-order
 [:q9-fleet-cljc-to-kotoba-migration
  :q8-qualified-reference-repository
  :q7-production-isolation
  :q6-adversarial-differential-qualification
  :q5-host-capability-kits
  :q4-tender-broker-boundary
  :q3-canonical-language-and-backend-parity
  :q2-capability-semantics
  :q1-threat-model-and-safety-claims]

 ;; Prerequisite-first order: reverse the list above for implementation. Q3
 ;; and Q4 may proceed in parallel after Q2; Q5 requires Q4.
 :implementation-order
 [:q1-threat-model-and-safety-claims
  :q2-capability-semantics
  :q3-canonical-language-and-backend-parity
  :q4-tender-broker-boundary
  :q5-host-capability-kits
  :q6-adversarial-differential-qualification
  :q7-production-isolation
  :q8-qualified-reference-repository
  :q9-fleet-cljc-to-kotoba-migration]

 :qualification-stages
 {:q1-threat-model-and-safety-claims
  {:deliverables [:t1-memory :t2-effect :t3-confinement :t4-determinism
                  :t5-resource-bounds :t6-supply-chain :t7-backend-parity
                  :t8-host-resource-scope]
   :gate "Every claim has a named owner, TCB, negative test and residual risk."}
  :q2-capability-semantics
  {:deliverables [:typed-capability-value :effect-to-import-closure
                  :scope-attenuation :no-wildcard :revocation-model]
   :gate "Language, compiler, policy and runtime use one capability identity and scope vocabulary."}
  :q3-canonical-language-and-backend-parity
  {:deliverables [:one-guest-grammar :shared-conformance-manifest
                  :accept-reject-diagnostic-parity :result-and-effect-trace-parity]
   :gate "kotoba and compiler cannot silently accept, reject or interpret the same guest differently."}
  :q4-tender-broker-boundary
  {:deliverables [:aiueos-decides :kototama-enforces :artifact-admission
                  :missing-host-means-capability-absence]
   :gate "The tender cannot mint grants and the broker cannot bypass artifact admission."}
  :q5-host-capability-kits
  {:deliverables [:narrow-domain-abi :scope-check :quota :timeout
                  :max-output :receipt :negative-fixtures]
   :gate "Every external effect has fail-closed resource-scope tests; generic shell/eval/ambient fs/net capabilities are absent."}
  :q6-adversarial-differential-qualification
  {:deliverables [:historical-exploit-regressions :valid-program-property-corpus
                  :almost-valid-fuzz-corpus :artifact-mutation
                  :reproducible-build :cross-backend-differential]
   :gate "No known escape succeeds; accepted programs agree and rejected programs fail closed at every entry path."}
  :q7-production-isolation
  {:deliverables [:per-guest-isolation :network-deny-default
                  :filesystem-deny-default :cpu-wall-memory-output-limits
                  :runtime-digest-evidence]
   :gate "Compromise of a guest or Wasm engine is contained by a second OS boundary."}
  :q8-qualified-reference-repository
  {:deliverables [:pure-component-port :capability-provider-port
                  :native-primitive-boundary :cljc-oracle-shadow
                  :qualification-report :independent-adversarial-review]
   :gate "One representative repository passes Q1-Q7 before its CLJC oracle is retired."}
  :q9-fleet-cljc-to-kotoba-migration
  {:deliverables [:inventory :dependency-waves :per-repo-evidence
                  :rollback-and-compatibility-policy]
   :gate "Migration proceeds by qualified waves, never by extension-only bulk rename."}}

