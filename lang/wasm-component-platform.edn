{:kotoba.lang.wasm-component/format :v1
 :status :specified
 :target :wasm-component-kotoba-v1
 :upstream
 {:component-model {:revision "e6bb1e456e946abd01173755468134d7c75c9f07"
                    :source "https://github.com/WebAssembly/component-model"}
  :wasi {:version "0.3.0"
         :revision "3ee2a590c766594ae44a54730fc74fc27da5c609"
         :source "https://github.com/WebAssembly/WASI/releases/tag/v0.3.0"}
  :compatibility [{:version "0.2.11"
                   :revision "ed73919426173babd88ae145e31deca3d484bbd0"
                   :status :legacy-explicit}]}
 :world {:construction :per-component
         :imports :declared-effects-only
         :exports :declared-functions-only
         :undeclared-imports :reject
         :ambient-wasi false}
 :function-modes
 {:sync {:wit :func :default true}
  :async {:wit :async-func :effect :component/async
          :values [:future :stream]
          :requires [:cancellation :deadline :item-budget :byte-budget]}}
 :type-rules
 {:scalars {:i64 :s64 :f32 :f32 :f64 :f64 :bool :bool :string :string}
  :keyword {:wit :string :validator :canonical-keyword}
  :vector {:wit :list :validator :bounded-items}
  :set {:wit :list :validator :bounded-canonical-unique}
  :map {:wit :list-of-entry-records :validator :bounded-canonical-unique-keys}
  :option :option :result :result :record :record :variant :variant
  :recursive-schema :reject-v1}
 :ownership
 {:language [:source-effects :type-semantics :bounds :async-semantics]
  :compiler [:wit-world :canonical-abi :component-encoding]
  :kototama [:admission :composition :provider-binding :async-runtime :budgets]}}
