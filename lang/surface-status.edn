   :backend-bounds {:compiler 128 :kotoba-wasm 128 :kotoba-cljs 128}
   :limits [:same-runtime-representation-as-list :no-runtime-vector-tag]
   :performance-choice :intentional-persistent-pair-chain-not-vector-trie
   :semantic-choice :intentional-untagged-pair-representation}
  :set-literal
  {:disposition :implemented-partial
   :reader :accepted
   :implementation #{:compiler :kotoba-wasm :kotoba-cljs}
   :language-semantics :bounded-unique-pair-chain
   :operations #{contains? conj disj}
   :admission-limit 16
   :determinism :source-forms-sorted-before-lowering
   :conformance :bounded-set-literal-and-operations
   :performance-choice :intentional-persistent-linear-set-not-hash-trie
   :note "Runtime-equal duplicates are removed; this remains an untagged linear set representation."}
  :map-function
  {:disposition :implemented-partial
   :reader :ordinary-symbol
   :implementation #{:compiler :kotoba-wasm :kotoba-cljs}
   :language-semantics :bounded-eager-one-to-five-collections
   :distinct-from :map-literal
   :callback {:portable #{:named-function :inline-fn :first-class-closure-value}}
   :callback-bounds {:named-or-inline-max-collections 5
                     :closure-value-max-collections 4}
   :abi-bound {:max-collections 5 :disposition :intentional-security-constraint}
   :conformance :bounded-named-higher-order-collections
   :missing []
   :note "Do not diagnose this as lack of map literals; the implemented slice is eager and fuel-bounded."}
  :persistent-collection-semantics
  {:disposition :implemented-partial
   :implementation #{:compiler :kotoba-wasm :kotoba-cljs}
   :operations #{count nth peek pop keys vals get assoc dissoc conj disj contains?}
   :persistence "operations return new pair-chain values without mutating inputs"
   :backend-bounds {:compiler :fuel-bounded
                    :kotoba-wasm :fuel-bounded
                    :kotoba-cljs :fuel-bounded}
   :representation-choice :persistent-structurally-shared-pair-chains
   :not-required-for-language-semantics [:hamt :vector-trie :hash-set-trie]
   :identity-contract {:dispatch :shape-directed
                       :runtime-tags :intentional-semantic-simplification
                       :reason "The bounded profile exposes operations, not Clojure collection class identity predicates."}
   :collection-protocol-contract :statically-lowered-operations
   :performance-contract {:lookup :linear-bounded
                          :update :persistent-structural-sharing
                          :literal-limit 128
                          :primary-transform-fuel 128
                          :multi-source-map-note "two-to-five-source map retains the static eight-step specialization pending a compact helper state ABI"}
   :missing []}}

