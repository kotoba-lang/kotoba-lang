{:kotoba.lang.surface-status/version 1
 :kotoba.lang.surface-status/profile-version 4
 :kotoba.lang.surface-status/as-of "2026-07-18"
 :kotoba.lang.surface-status/authority "kotoba-lang/kotoba-lang"
 :kotoba.lang.surface-status/adr "docs/adr/ADR-kotoba-language-surface-status.md"

 :dispositions
 {:intentional-security-constraint
  {:meaning "Excluded to preserve a named component safety invariant; widening requires an ADR and fail-closed enforcement."}
  :intentional-semantic-simplification
  {:meaning "Deliberately narrower than Clojure for deterministic, portable, or verifiable execution."}
  :implemented-partial
  {:meaning "Usable in at least one current backend, with the recorded semantic or parity limits."}
  :not-yet-implemented
  {:meaning "Not a safety prohibition; representation, bounded semantics, conformance, or backend parity is unfinished."}}

 :invariants
 {:no-ambient-authority
  {:disposition :intentional-security-constraint
   :surface #{eval load load-file require use ns-resolve resolve}
   :reason "Components cannot manufacture code or authority from ambient process state."}
  :no-interop
  {:disposition :intentional-security-constraint
   :surface #{import new . ..}
   :reason "Arbitrary JVM/JS object and method access bypasses capability admission."}
  :no-ambient-mutation
  {:disposition :intentional-security-constraint
   :surface #{set! alter-var-root atom swap! reset! ref dosync volatile! binding var}
   :reason "External mutable state is provider-owned and capability/policy mediated; component-local state must use an explicitly bounded model."}
  :no-unbounded-concurrency
  {:disposition :intentional-security-constraint
   :surface #{future pmap agent send send-off locking}
   :reason "Component scheduling and resources must remain tender-controlled and bounded."}
  :no-guest-macros
  {:disposition :intentional-security-constraint
   :surface #{defmacro}
   :reason "The safe component surface must be statically inspectable before execution."}
  :explicit-errors
  {:disposition :intentional-security-constraint
   :surface #{throw try catch}
   :reason "Component/provider effects use explicit result/error values rather than hidden exception paths."}
  :bounded-admission
  {:disposition :intentional-security-constraint
   :limits {:max-functions 1024
            :max-parameters 5
            :max-bindings 4096
            :max-symbol-chars 128
            :max-expression-nodes 50000
            :max-list-items 128
            :max-source-bytes 1048576
            :max-reader-depth 512}
   :reason "Untrusted and generated programs must fail closed under finite admission and execution resources."}
  :capability-only-affinity
  {:disposition :intentional-semantic-simplification
   :reason "Affine consumption is scoped to capability values; a general ownership/borrow/lifetime system is intentionally absent."
   :related-adr "docs/adr/ADR-safe-capability-language.md"}}

 :collections
 {:map-literal
