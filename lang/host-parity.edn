{:kotoba.lang.host-parity/version 1
 :kotoba.lang.host-parity/adr "adr-2607183900-kotoba-component-language-runtime-roles"
 :kotoba.lang.host-parity/level "L5-partial"
 :kotoba.lang.host-parity/note
 "SSoT matrix for actor:host import availability across JVM tender, browser
  (wasm-webcomponent), and Node. Missing provider == capability absence: components
  must not assume an import is ambient just because it compiles.
  Lifted from kototama.browser/host-impl; extend here, not in per-host forks."

 :hosts #{:jvm :browser :node}
 ;; Status: :yes | :no | :inject | :coop-or-inject
 :imports
 {:gen-keypair     {:jvm :yes :browser :yes :node :yes
                    :wasm-field "gen_keypair"
                    :note "browser: @noble/curves vendored sync Ed25519"}
  :sign            {:jvm :yes :browser :yes :node :yes :wasm-field "sign"}
  :verify          {:jvm :yes :browser :yes :node :yes :wasm-field "verify"}
  :sha256-hex      {:jvm :yes :browser :yes :node :yes :wasm-field "sha256_hex"}
  :http-post       {:jvm :yes :browser :coop-or-inject :node :inject
                    :wasm-field "http_post"
                    :note "inject opts.httpPost; browser SAB bridge needs COOP/COEP; JSPI experimental"}
  :log-read        {:jvm :yes :browser :yes :node :yes :wasm-field "log_read"}
  :log-write       {:jvm :yes :browser :yes :node :yes :wasm-field "log_write"}
  :clock-monotonic {:jvm :yes :browser :yes :node :yes :wasm-field "clock_monotonic"}
  :llm-infer       {:jvm :yes :browser :no  :node :inject
                    :wasm-field "llm_infer"
                    :note "browser: no sync network; node: opts.llmInfer inject"}}

 :acceptance
 {:browser-linkable-statuses #{:yes :coop-or-inject :inject}
  :min-browser-ratio 0.8
  :honest-gaps [:llm-infer-browser-absent :http-post-needs-coop-or-inject]}

 :runtime-hosts
 {:kototama-tender {:host :jvm :repo "kotoba-lang/kototama"}
  :wasm-webcomponent {:host :browser :repo "kotoba-lang/wasm-webcomponent"}
  :node-actor-host {:host :node :repo "kotoba-lang/wasm-webcomponent"}}}
