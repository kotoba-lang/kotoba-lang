{:kotoba.lang.host-parity/version 2
 :kotoba.lang.host-parity/adr "adr-2607180900-kotoba-guest-authoring-maturity"
 :kotoba.lang.host-parity/level "L5"
 :kotoba.lang.host-parity/note
 "SSoT matrix for actor:host import availability across JVM tender, browser
  (wasm-webcomponent), and Node. Missing host == capability absence: guests
  must not assume an import is ambient just because it compiles.
  Lifted from kototama.browser/host-impl; extend here, not in per-host forks.
  L5 adds :conformance cases — same guest expectations per host."

 :hosts #{:jvm :browser :node}
 ;; Status: :yes | :no | :inject | :coop-or-inject
 :imports
 {:gen-keypair     {:jvm :yes :browser :yes :node :yes
                    :wasm-field "gen_keypair"
                    :note "browser: @noble/curves vendored sync Ed25519"}
  :sign            {:jvm :yes :browser :yes :node :yes :wasm-field "sign"}
  :verify          {:jvm :yes :browser :yes :node :yes :wasm-field "verify"}
  :sha256-hex      {:jvm :yes :browser :yes :node :yes :wasm-field "sha256_hex"}
  :http-post       {:jvm :yes :browser :coop-or-inject :node :inject
                    :wasm-field "http_post"
                    :note "inject opts.httpPost; browser SAB bridge needs COOP/COEP; JSPI experimental"}
  :log-read        {:jvm :yes :browser :yes :node :yes :wasm-field "log_read"}
  :log-write       {:jvm :yes :browser :yes :node :yes :wasm-field "log_write"}
  :clock-monotonic {:jvm :yes :browser :yes :node :yes :wasm-field "clock_monotonic"}
  :llm-infer       {:jvm :yes :browser :no  :node :inject
                    :wasm-field "llm_infer"
                    :note "browser: no sync network; node: opts.llmInfer inject"}}

 :acceptance
 {:browser-linkable-statuses #{:yes :coop-or-inject :inject}
  :min-browser-ratio 0.8
  :honest-gaps [:llm-infer-browser-absent :http-post-needs-coop-or-inject]}

 ;; L5: declarative cross-host conformance. A fixture is pure data; runners
 ;; (kotoba.lang.host-parity/run-conformance) assert expected availability.
 ;; Rule: host status :no => :capability-absent (never ambient success).
 :conformance
 {:schema :kotoba.lang.host-conformance/v1
  :rule "missing host import == capability absence"
  :linkable-statuses #{:yes :coop-or-inject :inject}
  :cases
  [{:id :sha256-hex-jvm-available
    :import :sha256-hex :host :jvm :expect :available}
   {:id :sha256-hex-browser-available
    :import :sha256-hex :host :browser :expect :available}
   {:id :sha256-hex-node-available
    :import :sha256-hex :host :node :expect :available}
   {:id :gen-keypair-all-available
    :import :gen-keypair :hosts [:jvm :browser :node] :expect :available}
   {:id :llm-infer-jvm-available
    :import :llm-infer :host :jvm :expect :available}
   {:id :llm-infer-browser-absent
    :import :llm-infer :host :browser :expect :capability-absent}
   {:id :llm-infer-node-available
    :import :llm-infer :host :node :expect :available
    :note "node status is :inject — still linkable under inject opts"}
   {:id :http-post-browser-linkable
    :import :http-post :host :browser :expect :available
    :note "coop-or-inject counts as available for linkability"}
   {:id :http-post-node-linkable
    :import :http-post :host :node :expect :available}
   {:id :sign-browser-available
    :import :sign :host :browser :expect :available}
   {:id :verify-jvm-available
    :import :verify :host :jvm :expect :available}
   {:id :clock-monotonic-all
    :import :clock-monotonic :hosts [:jvm :browser :node] :expect :available}]}

 :runtime-hosts
 {:kototama-tender {:host :jvm :repo "kotoba-lang/kototama"}
  :wasm-webcomponent {:host :browser :repo "kotoba-lang/wasm-webcomponent"}
  :node-actor-host {:host :node :repo "kotoba-lang/wasm-webcomponent"}}}
