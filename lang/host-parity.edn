{:kotoba.lang.host-parity/version 2
 :kotoba.lang.host-parity/adr "adr-2607180900-kotoba-guest-authoring-maturity"
 :kotoba.lang.host-parity/level "L5"
 :kotoba.lang.host-parity/extension-verification-adr "adr-2607198100-kotoba-extension-verification"
 :kotoba.lang.host-parity/note
 "SSoT matrix for actor:host import availability across JVM tender, browser
  (wasm-webcomponent), and Node. Missing host == capability absence: guests
  must not assume an import is ambient just because it compiles.
  Lifted from kototama.browser/host-impl; extend here, not in per-host forks.
  L5 adds :conformance cases — same guest expectations per host."

 :hosts #{:jvm :browser :node}
 :required-imports
 #{:gen-keypair :sign :verify :kagi-sign :sha256-hex :http-post
   :transport-connect :tls-open :tls-server-end-point :transport-write
   :transport-read :transport-close :http-open :http-write :http-read
   :http-close :http-get :db-open :db-write :db-read :db-close :db-exchange
   :pg-simple-query :pg-open :pg-query :pg-query-state :pg-prepare
   :pg-prepare-typed :pg-execute-params2 :pg-execute-params :pg-bind-portal
   :pg-fetch-portal :pg-close-portal :pg-copy-out :pg-copy-in
   :pg-execute-batch :pg-session-reset :pg-pool-open :pg-pool-acquire
   :pg-pool-query :pg-pool-release :pg-pool-stats :pg-pool-health
   :pg-pool-drain :pg-pool-close :pg-close-statement :pg-open-scram
   :pg-open-scram-random :pg-open-scram-cancellable-random
   :pg-cancel-authority-use :pg-close-scram :scram-sha256
   :pg-cancel-register :pg-cancel :random-bytes :log-read :log-write
   :clock-monotonic :llm-infer}
 :unlisted-import-default
 {:jvm :component-link :browser :no :node :no
  :note "declared actor:host import; no browser or Node provider"}
 :browser-profile
 {:required
  #{:gen-keypair :sign :verify :sha256-hex :http-post :http-get
    :random-bytes :log-read :log-write :clock-monotonic}
  :intentional-native-boundary
  #{:kagi-sign :transport-connect :tls-open :tls-server-end-point
    :transport-write :transport-read :transport-close
    :scram-sha256 :pg-cancel-register :pg-cancel}
  :deferred-provider-components
  #{:http-open :http-write :http-read :http-close
    :db-open :db-write :db-read :db-close :db-exchange
    :pg-simple-query :pg-open :pg-query :pg-query-state :pg-prepare
    :pg-prepare-typed :pg-execute-params2 :pg-execute-params
    :pg-bind-portal :pg-fetch-portal :pg-close-portal :pg-copy-out
    :pg-copy-in :pg-execute-batch :pg-session-reset
    :pg-pool-open :pg-pool-acquire :pg-pool-query :pg-pool-release
    :pg-pool-stats :pg-pool-health :pg-pool-drain :pg-pool-close
    :pg-close-statement :pg-open-scram :pg-open-scram-random
    :pg-open-scram-cancellable-random :pg-cancel-authority-use
    :pg-close-scram}
  :deferred-host-injection #{:llm-infer}
  :minimum-required-coverage 1.0}
 ;; Status: :yes | :no | :inject | :coop-or-inject
 :imports
 {:gen-keypair     {:jvm :yes :browser :yes :node :yes
                    :wasm-field "gen_keypair"
                    :note "browser: @noble/curves vendored sync Ed25519"}
  :sign            {:jvm :yes :browser :yes :node :yes :wasm-field "sign"}
  :verify          {:jvm :yes :browser :yes :node :yes :wasm-field "verify"}
  :kagi-sign       {:jvm :yes :browser :no :node :inject :wasm-field "kagi_sign"
                    :note "decision-aware trusted adapter only; finite quota; key never enters guest or generic host"}
  :sha256-hex      {:jvm :yes :browser :yes :node :yes :wasm-field "sha256_hex"}
  :http-post       {:jvm :yes :browser :coop-or-inject :node :inject
                    :wasm-field "http_post"
                    :note "inject opts.httpPost; browser SAB bridge needs COOP/COEP; JSPI experimental"}
  :transport-connect {:jvm :inject :browser :no :node :inject
                      :wasm-field "transport_connect"
                      :note "worker/SAB broker; exact endpoint and resolved-address allowlists"}
  :tls-open        {:jvm :inject :browser :no :node :inject
                    :wasm-field "tls_open" :note "verified TLS; exact SNI; no verification-disable switch"}
  :transport-write {:jvm :inject :browser :no :node :inject
                    :wasm-field "transport_write"}
  :transport-read  {:jvm :inject :browser :no :node :inject
                    :wasm-field "transport_read"}
  :transport-close {:jvm :inject :browser :no :node :inject
                    :wasm-field "transport_close"}
  :http-open       {:jvm :component-link :browser :no :node :component-link
                    :wasm-field "http_open"}
  :http-write      {:jvm :component-link :browser :no :node :component-link
                    :wasm-field "http_write"}
  :http-read       {:jvm :component-link :browser :no :node :component-link
                    :wasm-field "http_read"}
  :http-close      {:jvm :component-link :browser :no :node :component-link
                    :wasm-field "http_close"}
  :http-get        {:jvm :component-link :browser :inject :node :component-link
                    :wasm-field "http_get"
                    :note "Node links compiled .kotoba provider across independent memories; browser uses scoped injection"}
  :db-open         {:jvm :component-link :browser :no :node :component-link :wasm-field "db_open"}
  :db-write        {:jvm :component-link :browser :no :node :component-link :wasm-field "db_write"}
  :db-read         {:jvm :component-link :browser :no :node :component-link :wasm-field "db_read"}
  :db-close        {:jvm :component-link :browser :no :node :component-link :wasm-field "db_close"}
  :db-exchange     {:jvm :component-link :browser :no :node :component-link
                    :wasm-field "db_exchange" :note "compiled .kotoba framed DB provider over Node TLS"}
  :pg-open         {:jvm :component-link :browser :no :node :component-link
                    :wasm-field "pg_open" :note "compiled provider; SSLRequest, verified TLS and StartupMessage"}
  :pg-simple-query {:jvm :component-link :browser :no :node :component-link
                    :wasm-field "pg_simple_query"
                    :note "legacy one-shot path; SSLRequest and exact AuthOK/Ready required"}
  :pg-query        {:jvm :component-link :browser :no :node :component-link
                    :wasm-field "pg_query" :note "bounded PostgreSQL SimpleQuery through independent memories"}
  :pg-query-state  {:jvm :component-link :browser :no :node :component-link
                    :wasm-field "pg_query_state" :note "result kind, ReadyForQuery state and SQLSTATE metadata"}
  :pg-open-scram-random {:jvm :component-link :browser :no :node :component-link
                         :wasm-field "pg_open_scram_random"
                         :note "compiled SCRAM provider; host-custodied credential and bounded randomness"}
  :pg-open-scram {:jvm :component-link :browser :no :node :component-link
                  :wasm-field "pg_open_scram"
                  :note "bounded caller nonce; purpose-bound credential remains host-custodied"}
  :pg-open-scram-cancellable-random {:jvm :component-link :browser :no :node :component-link
                                     :wasm-field "pg_open_scram_cancellable_random"
                                     :note "returns i64 channel and copied opaque one-shot cancel authority"}
  :pg-cancel-authority-use {:jvm :component-link :browser :no :node :component-link
                            :wasm-field "pg_cancel_authority_use"
                            :note "one-shot authority; fixed pinned-peer CancelRequest"}
  :pg-close-scram {:jvm :component-link :browser :no :node :component-link
                   :wasm-field "pg_close_scram"}
  :pg-prepare     {:jvm :component-link :browser :no :node :component-link
                   :wasm-field "pg_prepare" :note "named Parse/Describe/Sync with bounded buffers"}
  :pg-execute-params2 {:jvm :component-link :browser :no :node :component-link
                       :wasm-field "pg_execute_params2"
                       :note "Bind values remain separate from query text; error recovery qualified"}
  :pg-close-statement {:jvm :component-link :browser :no :node :component-link
                       :wasm-field "pg_close_statement"}
  :pg-prepare-typed {:jvm :component-link :browser :no :node :component-link
                     :wasm-field "pg_prepare_typed"
                     :note "bounded explicit OID list in Parse"}
  :pg-execute-params {:jvm :component-link :browser :no :node :component-link
                      :wasm-field "pg_execute_params"
                      :note "validated text/binary/null Bind descriptor"}
  :pg-bind-portal {:jvm :component-link :browser :no :node :component-link
                   :wasm-field "pg_bind_portal"
                   :note "named portal Bind separated from prepared statement"}
  :pg-fetch-portal {:jvm :component-link :browser :no :node :component-link
                    :wasm-field "pg_fetch_portal"
                    :note "bounded Execute; PortalSuspended can resume in transaction"}
  :pg-close-portal {:jvm :component-link :browser :no :node :component-link
                    :wasm-field "pg_close_portal"}
  :pg-execute-batch {:jvm :component-link :browser :no :node :component-link
                     :wasm-field "pg_execute_batch"
                     :note "up to eight Bind/Execute items under one Sync; error recovery qualified"}
  :pg-session-reset {:jvm :component-link :browser :no :node :component-link
                     :wasm-field "pg_session_reset"
                     :note "ROLLBACK then DISCARD ALL; state removal and connection reuse qualified"}
  :pg-copy-out {:jvm :component-link :browser :no :node :component-link
                :wasm-field "pg_copy_out"
                :note "validated CopyOutResponse/Data/Done/CommandComplete sequence"}
  :pg-copy-in {:jvm :component-link :browser :no :node :component-link
               :wasm-field "pg_copy_in"
               :note "bounded CopyData followed by CopyDone and ReadyForQuery"}
  :pg-pool-open {:jvm :native-provider :browser :no :node :native-provider :wasm-field "pg_pool_open"}
  :pg-pool-acquire {:jvm :native-provider :browser :no :node :native-provider :wasm-field "pg_pool_acquire"}
  :pg-pool-query {:jvm :native-provider :browser :no :node :native-provider :wasm-field "pg_pool_query"}
  :pg-pool-release {:jvm :native-provider :browser :no :node :native-provider :wasm-field "pg_pool_release"
                    :note "affine lease consumption includes session reset"}
  :pg-pool-stats {:jvm :native-provider :browser :no :node :native-provider :wasm-field "pg_pool_stats"
                  :note "fixed 32-byte bounded metrics record"}
  :pg-pool-health {:jvm :native-provider :browser :no :node :native-provider :wasm-field "pg_pool_health"}
  :pg-pool-drain {:jvm :native-provider :browser :no :node :native-provider :wasm-field "pg_pool_drain"}
  :pg-pool-close {:jvm :native-provider :browser :no :node :native-provider :wasm-field "pg_pool_close"}
  :log-read        {:jvm :yes :browser :yes :node :yes :wasm-field "log_read"}
  :log-write       {:jvm :yes :browser :yes :node :yes :wasm-field "log_write"}
  :clock-monotonic {:jvm :yes :browser :yes :node :yes :wasm-field "clock_monotonic"}
  :random-bytes    {:jvm :yes :browser :yes :node :yes :wasm-field "random_bytes"
                    :note "bounded OS/Web Crypto randomness; default byte quota zero"}
  :tls-server-end-point
  {:jvm :yes :browser :no :node :inject :wasm-field "tls_server_end_point"
   :note "RFC 5929 peer-certificate digest bound to an affine TLS handle"}
  :llm-infer       {:jvm :yes :browser :no  :node :inject
                    :wasm-field "llm_infer"
                    :note "browser: no sync network; node: opts.llmInfer inject"}
  :scram-sha256    {:jvm :yes :browser :no :node :inject
                    :wasm-field "scram_sha256"
                    :note "native non-exporting credential store required"}
  :pg-cancel-register {:jvm :yes :browser :no :node :inject
                       :wasm-field "pg_cancel_register"
                       :note "BackendKeyData becomes an opaque one-shot authority"}
  :pg-cancel {:jvm :yes :browser :no :node :inject
              :wasm-field "pg_cancel"
              :note "pinned-peer CancelRequest only"}}

 :acceptance
 {:browser-linkable-statuses #{:yes :coop-or-inject :inject}
  :min-browser-ratio 0.0
  :honest-gaps [:global-browser-parity-10-of-59
                :deferred-provider-components-38
                :llm-infer-browser-absent :http-post-needs-coop-or-inject
                :http-get-requires-finite-quota-and-https-scope
                :scram-secret-provider-browser-absent
                :tls-channel-binding-browser-absent]}

 ;; L5: declarative cross-host conformance. A fixture is pure data; runners
 ;; (kotoba.lang.host-parity/run-conformance) assert expected availability.
 ;; Rule: host status :no => :capability-absent (never ambient success).
 :conformance
 {:schema :kotoba.lang.host-conformance/v1
  :rule "missing host import == capability absence"
  :linkable-statuses #{:yes :coop-or-inject :inject}
  :cases
  [{:id :sha256-hex-jvm-available
    :import :sha256-hex :host :jvm :expect :available}
   {:id :sha256-hex-browser-available
    :import :sha256-hex :host :browser :expect :available}
   {:id :sha256-hex-node-available
    :import :sha256-hex :host :node :expect :available}
   {:id :gen-keypair-all-available
    :import :gen-keypair :hosts [:jvm :browser :node] :expect :available}
   {:id :llm-infer-jvm-available
    :import :llm-infer :host :jvm :expect :available}
   {:id :llm-infer-browser-absent
    :import :llm-infer :host :browser :expect :capability-absent}
   {:id :llm-infer-node-available
    :import :llm-infer :host :node :expect :available
    :note "node status is :inject — still linkable under inject opts"}
   {:id :http-post-browser-linkable
    :import :http-post :host :browser :expect :available
    :note "coop-or-inject counts as available for linkability"}
   {:id :http-post-node-linkable
    :import :http-post :host :node :expect :available}
   {:id :sign-browser-available
    :import :sign :host :browser :expect :available}
   {:id :verify-jvm-available
    :import :verify :host :jvm :expect :available}
   {:id :clock-monotonic-all
    :import :clock-monotonic :hosts [:jvm :browser :node] :expect :available}]}

 :runtime-hosts
 {:kototama-tender {:host :jvm :repo "kotoba-lang/kototama"}
  :wasm-webcomponent {:host :browser :repo "kotoba-lang/wasm-webcomponent"}
  :node-actor-host {:host :node :repo "kotoba-lang/wasm-webcomponent"}}}
