{:kotoba.cli.contract/version 1
 :kotoba.cli.contract/scope
 {:owner :kotoba-lang
  :authority :cljc-edn
  :host-adapter-targets [:rust]
  :description "Data-first command contract for the public kotoba CLI. Host CLIs should adapt to this contract instead of defining protocol semantics."}
 :kotoba.cli.contract/tier-labels
 {:m0 {:label "M0"
       :meaning "Documented command surface and option vocabulary."}
  :m1 {:label "M1"
       :meaning "Machine-readable command contract suitable for host adapters."}
  :m2 {:label "M2"
       :meaning "Validated command contract with conformance fixtures."}
  :m3 {:label "M3"
       :meaning "Host adapters are generated or mechanically checked against the contract."}}
 :kotoba.cli.contract/option-types
 {:boolean {:description "Presence flag or explicit boolean value."}
  :string  {:description "Single string argument."}
  :path    {:description "Filesystem path interpreted by the host adapter."}
  :edn     {:description "EDN value or path to an EDN document, as specified by the option."}
  :enum    {:description "One value from the option's :values vector."}
  :int     {:description "Integer value."}}
 :kotoba.cli.contract/commands
 [{:id :run
   :tier :m1
   :summary "Compile and run a Kotoba entry point."
   :positionals [{:id :entry
                  :type :path
                  :required? false
                  :description "Kotoba, CLJ, CLJC, or CLJS source file. Optional when :expr is supplied."}]
   :options [{:id :expr
              :flags ["-e" "--expr"]
              :type :string
              :description "Inline expression compiled as exported main; compile-and-run sugar, not runtime eval."}
             {:id :source-path
              :flags ["-S" "--source-path"]
              :type :path
              :repeatable? true
              :env "KOTOBA_SOURCE_PATH"
              :description "Namespace source root. KOTOBA_CLJ_PATH remains a compatibility alias outside this contract."}
             {:id :target
              :flags ["--target"]
              :type :enum
              :values [:kotoba :clj :cljs]
              :default :kotoba
              :description "Reader target for portable source."}
             {:id :function
              :flags ["--function"]
              :type :string
              :default "main"
              :description "Exported function to invoke."}
             {:id :arg
              :flags ["--arg"]
              :type :edn
              :repeatable? true
              :description "EDN argument passed to the entry function."}
             {:id :json
              :flags ["--json"]
              :type :boolean
              :description "Emit machine-readable JSON result."}]}
  {:id :check
   :tier :m1
   :summary "Validate Kotoba source, contracts, or package metadata without running it."
   :positionals [{:id :input
                  :type :path
                  :required? false
                  :description "Source file, package manifest, lock file, or contract document."}]
   :options [{:id :kind
              :flags ["--kind"]
              :type :enum
              :values [:source :package :lock :cli-contract :auto]
              :default :auto
              :description "Validation domain."}
             {:id :source-path
              :flags ["-S" "--source-path"]
              :type :path
              :repeatable? true
              :description "Namespace source root for source checks."}
             {:id :target
              :flags ["--target"]
              :type :enum
              :values [:kotoba :clj :cljs]
              :default :kotoba
              :description "Reader target for portable source checks."}
             {:id :safe
              :flags ["--safe"]
              :type :boolean
              :default true
              :description "Apply the capability-safe Kotoba profile."}
             {:id :json
              :flags ["--json"]
              :type :boolean
              :description "Emit machine-readable diagnostics."}]}
  {:id :db
   :tier :m1
   :summary "Interact with the Kotoba data substrate through explicit data operations."
   :subcommands [:connect :query :transact :pull :status]
   :options [{:id :db
              :flags ["--db"]
              :type :string
              :required? true
              :description "Database alias, URI, or environment-selected handle."}
             {:id :operation
              :flags ["--op"]
              :type :enum
              :values [:connect :query :transact :pull :status]
              :description "Data operation. Mirrors the supported subcommands for adapters without nested command support."}
             {:id :input
              :flags ["-f" "--file"]
              :type :path
              :description "EDN query, transaction, or pull request file."}
             {:id :param
              :flags ["--param"]
              :type :edn
              :repeatable? true
              :description "EDN parameter binding for query-like operations."}
             {:id :json
              :flags ["--json"]
              :type :boolean
              :description "Emit machine-readable result."}]}
  {:id :git
   :tier :m1
   :summary "Expose Kotoba repository operations as data, not shell-specific behavior."
   :subcommands [:init :status :commit :sync]
   :options [{:id :repo
              :flags ["--repo"]
              :type :path
              :default "."
              :description "Repository root."}
             {:id :operation
              :flags ["--op"]
              :type :enum
              :values [:init :status :commit :sync]
              :description "Repository operation. Mirrors subcommands for simple host adapters."}
             {:id :message
              :flags ["-m" "--message"]
              :type :string
              :description "Commit message for commit-like operations."}
             {:id :ref
              :flags ["--ref"]
              :type :string
              :description "Branch, tag, or revision reference."}
             {:id :json
              :flags ["--json"]
              :type :boolean
              :description "Emit machine-readable repository status."}]}
  {:id :rad
   :tier :m1
   :summary "Run rapid application development workflows over Kotoba packages."
   :subcommands [:new :build :test :export]
   :options [{:id :project
              :flags ["--project"]
              :type :path
              :default "."
              :description "Project root."}
             {:id :operation
              :flags ["--op"]
              :type :enum
              :values [:new :build :test :export]
              :description "RAD operation. Mirrors subcommands for simple host adapters."}
             {:id :template
              :flags ["--template"]
              :type :string
              :description "Project or artifact template."}
             {:id :profile
              :flags ["--profile"]
              :type :enum
              :values [:dev :test :release]
              :default :dev
              :description "Build or test profile."}
             {:id :output
              :flags ["-o" "--output"]
              :type :path
              :description "Output path for build/export artifacts."}
             {:id :json
              :flags ["--json"]
              :type :boolean
              :description "Emit machine-readable workflow result."}]}
  {:id :deploy
   :tier :m1
   :summary "Plan and apply deployment operations from Kotoba package data."
   :subcommands [:plan :apply :status :rollback]
   :options [{:id :manifest
              :flags ["--manifest"]
              :type :path
              :default "package-manifest.edn"
              :description "Package or deployment manifest."}
             {:id :operation
              :flags ["--op"]
              :type :enum
              :values [:plan :apply :status :rollback]
              :description "Deployment operation. Mirrors subcommands for simple host adapters."}
             {:id :target
              :flags ["--target"]
              :type :string
              :required? true
              :description "Deployment target name or URI."}
             {:id :dry-run
              :flags ["--dry-run"]
              :type :boolean
              :default true
              :description "Plan without applying host-side changes."}
             {:id :revision
              :flags ["--revision"]
              :type :string
              :description "Revision to deploy or roll back to."}
             {:id :json
              :flags ["--json"]
              :type :boolean
              :description "Emit machine-readable deployment status."}]}
  {:id :hinshitsu
   :tier :m1
   :summary "Run software-quality checks (evidence, gates, coverage, visual regression) as data."
   :subcommands [:evidence :gate :coverage :mokushi]
   :options [{:id :input
              :flags ["-f" "--file"]
              :type :path
              :description "EDN evidence document, gate spec, or coverage spec."}
             {:id :operation
              :flags ["--op"]
              :type :enum
              :values [:evidence :gate :coverage :mokushi]
              :description "Quality operation. Mirrors subcommands for simple host adapters."}
             {:id :baseline
              :flags ["--baseline"]
              :type :path
              :description "Baseline artifact path for mokushi visual comparisons."}
             {:id :candidate
              :flags ["--candidate"]
              :type :path
              :description "Candidate artifact path for mokushi visual comparisons."}
             {:id :threshold
              :flags ["--threshold"]
              :type :string
              :default "0.02"
              :description "Maximum allowed RMSE distortion for mokushi visual comparisons."}
             {:id :required-check
              :flags ["--required-check"]
              :type :string
              :repeatable? true
              :description "Check name that must be present and passed for a gate to succeed."}
             {:id :json
              :flags ["--json"]
              :type :boolean
              :description "Emit machine-readable quality-check result."}]}]}
