{:kotoba.lang/profile-version 4
 :kotoba.lang/default-reader-target :kotoba
 :kotoba.lang/source-extensions ["kotoba" "cljc" "cljk" "clj" "cljs"]
 :kotoba.lang/reader-targets
 {:kotoba {:reader-branches ["kotoba" "clj" "default"]
           :namespace-extension-priority ["kotoba" "cljc" "cljk" "clj" "cljs"]}
  :clj    {:reader-branches ["clj" "default"]
           :namespace-extension-priority ["cljc" "clj"]}
  :cljs   {:reader-branches ["cljs" "default"]
           :namespace-extension-priority ["cljc" "cljs"]}}
 :kotoba.lang/authoring-surface
 {:canonical-extension "kotoba"
  :portable-extension "cljc"
  :kotoba-branch "kotoba"
  :clj-kotoba-extension "cljk"
  :primary-source-extensions ["kotoba" "cljc" "cljk"]
  :host-source-extensions ["clj" "cljs"]
  :runtime-role-independent true
  :component-role-model "lang/component-role-model.edn"
  :web-kotoba-reader-target "kotoba"
  :web-kotoba-backend "kotoba-lang/compiler -> checked KIR -> kotoba-lang/kotoba-script -> restricted ESM"
  :note ".cljk means CLJ Kotoba and is compiled by the Kotoba compiler; it is not a JVM target. .kotoba is canonical capability-safe component source; it does not imply a guest-only runtime role. .cljc is common source across Clojure, ClojureScript, and Kotoba. .clj and .cljs retain their standard Clojure and ClojureScript meanings."}
 :kotoba.lang/guest-grammar "lang/guest-grammar.edn"
 :kotoba.lang/guest-grammar-adr "adr-2607183900-kotoba-component-language-runtime-roles"
 :kotoba.lang/surface-status "lang/surface-status.edn"
 :kotoba.lang/surface-status-adr "docs/adr/ADR-kotoba-language-surface-status.md"}
