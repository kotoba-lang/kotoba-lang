{:kotoba.lang.capability-semantics/version 1
 :kotoba.lang.capability-semantics/as-of "2026-07-18"
 :kotoba.lang.capability-semantics/qualification :q2
 :identity-keys [:cap/kind :cap/resource :cap/holder :cap/expires :cap/provenance]
 :grant-keys [:grant/kind :grant/resources :grant/expires :grant/id]
 :policy-keys [:policy/allow :policy/forbid-wildcard]
 :receipt-requirements
 [:receipt/cap :receipt/at :receipt/call :receipt/outcome]
 :rules
 {:plain-resource-is-not-authority true
  :unknown-kind :deny
  :missing-grant :deny
  :expired-grant :deny
  :empty-intersection :deny
  :effective-scope :requested-intersect-delegated-intersect-local-policy
  :scope-attenuation-only true
  :handler-receives :concrete-post-intersection-capability
  :attempt-always-receipted true
  :production-effective-wildcard :forbidden
  :wildcard-fixtures
  "The :any fixtures exercise intersection algebra only. A production local policy MUST set :policy/forbid-wildcard true, so :any can never become effective authority."}
 :kinds
 #{:graph-read :graph-write :infer
   :host/clipboard-read :host/clipboard-write :host/http :host/fs-read
   :host/fs-write :host/keychain-read :host/keychain-write :host/notify
   :host/ledger-append :host/graph-assert :host/graph-retract
   :host/graph-get-objects :host/graph-query :host/log-write
   :host/clock-monotonic :host/random-bytes :host/topic-publish
   :net/connect :crypto/tls :net/transport :component/http :component/database
   :secret/use-scram-sha256 :secret/use-postgresql-cancel
   :host/topic-subscribe :host/pci-config :host/dma-map :host/irq-subscribe
   :host/mmio-map :host/identity-keypair :host/identity-sign
   :host/identity-verify :host/hash-sha256 :host/http-post :host/log-read
   :host/kami-engine :vrm/asset-read :vrm/compose :vrm/preview :vrm/export
   :vrm/publish}
 :revocation
 {:compile-time "Signed package/module admission checks the current revoked signer set."
  :call-time "Expired or absent delegated grants are denied on every guarded host call."
  :long-running "Hosts must re-authorize at effect time; an admission-time grant is not a perpetual lease."
  :fail-closed true}}
