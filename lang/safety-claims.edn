{:kotoba.lang.safety-claims/version 1
 :kotoba.lang.safety-claims/as-of "2026-07-18"
 :kotoba.lang.safety-claims/qualification :q1
 :claims
 [{:id :t1-memory
   :claim "Admitted components cannot address runtime/native memory and component memory operations are bounded or trap."
   :owner "kotoba-lang/compiler"
   :tcb ["bounded reader" "frontend admission" "artifact verifier" "Wasm/native runtime"]
   :negative-evidence
   ["../compiler/test/kotoba/compiler/frontend_limits_test.clj"
    "../compiler/test/kotoba/compiler/security_fuzz_test.clj"
    "../compiler/test/kotoba/compiler/verifier_profile_test.clj"]
   :residual-risk
   ["runtime-engine vulnerabilities remain in the TCB"
    "native loaders require a second OS isolation boundary"]}
  {:id :t2-effect
   :claim "Every transitive component effect is declared and admitted before emission, including effects used by Kotoba-written providers."
   :owner "kotoba-lang/compiler"
   :tcb ["effect inference" "capability catalog" "frontend call graph"]
   :negative-evidence
   ["lang/capability-conformance/negative/effects_missing.edn"
    "../compiler/test/kotoba/compiler/admission_test.clj"]
   :residual-risk
   ["kotoba and compiler grammar/effect parity must be continuously compared"]}
  {:id :t3-confinement
   :claim "An ungranted capability is absent or unbound and cannot reach a provider or native handler."
   :owner "kotoba-lang/kotoba-lang"
   :tcb ["policy intersection" "compiler import emission" "tender import binding" "host guard"]
   :negative-evidence
   ["lang/capability-conformance/negative/empty_intersection.edn"
    "lang/capability-conformance/negative/host_dispatch_expired.edn"
    "test/kotoba/lang/capability_host_test.clj"]
   :residual-risk
   ["provider and native implementations must independently validate resource scope"
    "production effective grants must forbid wildcard scope"]}
  {:id :t4-determinism
   :claim "The same admitted source, target, policy and lock produce the same observable pure result and artifact bytes."
   :owner "kotoba-lang/compiler"
   :tcb ["canonical reader" "deterministic lowering" "pinned toolchain"]
   :negative-evidence
   ["../compiler/test/kotoba/compiler/property_test.clj"
    "../compiler/test/nbb/run.cljs"]
   :residual-risk
   ["host effects are deterministic only where their capability contract says so"]}
  {:id :t5-resource-bounds
   :claim "Source, admission, execution, memory and output use explicit finite bounds."
   :owner "kotoba-lang/compiler"
   :tcb ["admission limits" "fuel meter" "runtime quota" "supervisor timeout"]
   :negative-evidence
   ["../compiler/test/kotoba/compiler/frontend_limits_test.clj"
    "../kotoba/test/kotoba/wasm_exec_test.clj"]
   :residual-risk
   ["platform supervisors do not yet have equal production isolation evidence"]}
  {:id :t6-supply-chain
   :claim "Release admission binds artifact identity, trusted signer, validity and reproducible evidence."
   :owner "kotoba-lang/compiler"
   :tcb ["signature verifier" "trusted signer configuration" "clock" "revocation set"]
   :negative-evidence
   ["lang/package-conformance/negative/unsigned_manifest.edn"
    "lang/package-conformance/negative/revoked_signer_lock.edn"
    "lang/package-conformance/negative/expired_signer_lock.edn"]
   :residual-risk
   ["key custody and external revocation distribution remain operational TCB"]}
  {:id :t7-backend-parity
   :claim "A shared portable component has equal acceptance, result and effect trace across qualified backends."
   :owner "kotoba-lang/kotoba-lang"
   :tcb ["shared conformance manifest" "backend adapters" "comparison runner"]
   :negative-evidence
   ["lang/conformance/negative/runtime_require.cljc"
    "../kotoba/test/kotoba/language_conformance_test.clj"
    "../compiler/scripts/conformance.cljs"]
   :residual-risk
   ["compiler-only features are not portable and must be rejected by portable profiles"]}
  {:id :t8-host-resource-scope
   :claim "A component import reaches its provider or native handler only with a concrete post-intersection resource scope and emits a receipt."
   :owner "kotoba-lang/kotoba-lang"
   :tcb ["capability intersection" "host guard" "provider handler" "receipt sink"]
   :negative-evidence
   ["lang/capability-conformance/negative/empty_intersection.edn"
    "lang/capability-conformance/negative/expired_grant.edn"
    "test/kotoba/lang/capability_host_test.clj"]
   :residual-risk
   ["provider-specific path, redirect, symlink and tenant checks require Q5 kits"]}]}
